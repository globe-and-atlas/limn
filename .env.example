PORT=4177
GEE_PROJECT=your-google-cloud-project-id

# Option A: service-account JSON path outside the repo.
GEE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/earth-engine-service-account.json

# Option B: inline service-account fields.
# GEE_SERVICE_ACCOUNT_EMAIL=service-account-name@your-project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional browser/server API key. This is not a substitute for service-account auth.
# GEE_API_KEY=your-google-api-key

# Optional cache/dataset overrides.
GEE_MAP_CACHE_TTL_MS=2700000
GEE_S2_COLLECTION=COPERNICUS/S2_SR_HARMONIZED

# CDSE Copernicus Client Credentials (required on Sentinel Hub WMS mode or for python backend tools)
CDSE_CLIENT_ID=your-copernicus-client-id
CDSE_CLIENT_SECRET=your-copernicus-client-secret
